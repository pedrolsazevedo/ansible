ARG BASE_IMAGE=redhat/ubi9:latest@sha256:039095faabf1edde946ff528b3b6906efa046ee129f3e33fd933280bb6936221
FROM ${BASE_IMAGE}

RUN dnf update -y && \
    dnf install -y --allowerasing \
    curl \
    git \
    vim \
    wget \
    unzip \
    gnupg2 \
    bind-utils \
    openssl \
    gcc \
    gcc-c++ \
    make \
    sudo

COPY build/scripts/setup-homebrew.sh /tmp/setup-homebrew.sh
RUN /tmp/setup-homebrew.sh && rm /tmp/setup-homebrew.sh

CMD [ "bash" ]
