ARG BASE_IMAGE=redhat/ubi9:latest@sha256:9e6e193bfc3596a84d2a32f42d6b1552398ec9735b9a4e893a0fc3c6fbccb381
FROM ${BASE_IMAGE}

RUN dnf update -y && \
    dnf install -y \
    curl \
    git \
    vim \
    wget \
    unzip \
    gnupg2 \
    bind-utils \
    whois \
    openssl \
    gcc \
    gcc-c++ \
    make \
    sudo

COPY build/scripts/setup-homebrew.sh /tmp/setup-homebrew.sh
RUN /tmp/setup-homebrew.sh && rm /tmp/setup-homebrew.sh

CMD [ "bash" ]
