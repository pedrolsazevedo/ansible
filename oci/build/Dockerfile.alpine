FROM alpine:latest@sha256:25109184c71bdad752c8312a8623239686a9a2071e8825f20acb8f2198c3f659

RUN apk update && apk upgrade && \
    apk add --no-cache \
    curl \
    git \
    vim \
    wget \
    unzip \
    gnupg \
    bind-tools \
    whois \
    openssl \
    bash \
    build-base \
    helm \
    kubectl

CMD [ "bash" ]
