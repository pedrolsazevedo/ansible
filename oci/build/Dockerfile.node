FROM node:alpine@sha256:cf38e1f3c28ac9d81cdc0c51d8220320b3b618780e44ef96a39f76f7dbfef023

RUN apk update && apk upgrade && \
    apk add --no-cache \
    curl \
    git \
    vim \
    wget \
    unzip \
    gnupg \
    bind-tools \
    whois \
    openssl \
    bash \
    build-base \
    helm \
    kubectl

CMD [ "bash" ]
