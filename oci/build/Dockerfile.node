FROM node:alpine@sha256:5209bcaca9836eb3448b650396213dbe9d9a34d31840c2ae1f206cb2986a8543

RUN apk update && apk upgrade && \
    apk add --no-cache \
    curl \
    git \
    vim \
    wget \
    unzip \
    gnupg \
    bind-tools \
    whois \
    openssl \
    bash \
    build-base \
    helm \
    kubectl

CMD [ "bash" ]
