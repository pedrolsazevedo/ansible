FROM ubuntu:24.04@sha256:d1e2e92c075e5ca139d51a140fff46f84315c0fdce203eab2807c7e495eff4f9

RUN apt-get update && \
    apt-get upgrade -y && \
    apt-get install -y \
    curl \
    git \
    vim \
    wget \
    unzip \
    gpg \
    dnsutils \
    whois \
    openssl \
    build-essential \
    sudo

COPY build/scripts/setup-homebrew.sh /tmp/setup-homebrew.sh
RUN /tmp/setup-homebrew.sh && rm /tmp/setup-homebrew.sh

CMD [ "bash" ]
