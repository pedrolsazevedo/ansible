{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "labels": ["dependencies"],
  "assignees": ["@me"],
  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,
  "schedule": ["before 6am on monday"],
  "timezone": "America/Sao_Paulo",
  "packageRules": [
    {
      "description": "Pin Docker image digests",
      "matchCategories": ["docker"],
      "pinDigests": true,
      "separateMinorPatch": true,
      "separateMajorMinor": true
    },
    {
      "matchCategories": ["docker"],
      "matchFileNames": ["ansible/tests/docker-compose.yml", "ansible/tests/Dockerfile"],
      "enabled": true
    },
    {
      "description": "Ansible versions in vars/versions.yml",
      "matchFileNames": ["ansible/vars/versions.yml"],
      "matchManagers": ["custom.regex"],
      "enabled": true
    },
    {
      "description": "Group all Ansible role updates",
      "matchFileNames": ["ansible/roles/**/defaults/main.yml"],
      "groupName": "ansible-roles",
      "automerge": false
    },
    {
      "description": "Auto-merge minor and patch updates",
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "OCI base image updates",
      "matchFileNames": ["oci/build/**"],
      "matchCategories": ["docker"],
      "automerge": true,
      "automergeType": "pr"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/^ansible/vars/versions\\.yml$/"],
      "matchStrings": ["kubectl_version:\\s*\"v(?<currentValue>.*?)\""],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "kubernetes/kubernetes"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^ansible/vars/versions\\.yml$/"],
      "matchStrings": ["kind_version:\\s*\"v(?<currentValue>.*?)\""],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "kubernetes-sigs/kind"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^ansible/vars/versions\\.yml$/"],
      "matchStrings": ["rancher_desktop_version:\\s*\"(?<currentValue>.*?)\""],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "rancher-sandbox/rancher-desktop"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^ansible/vars/versions\\.yml$/"],
      "matchStrings": ["nvm_version:\\s*v(?<currentValue>.*)"],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "nvm-sh/nvm"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^ansible/vars/versions\\.yml$/"],
      "matchStrings": ["pyenv_python_version:\\s*\"(?<currentValue>.*?)\""],
      "datasourceTemplate": "github-tags",
      "depNameTemplate": "python/cpython",
      "extractVersionTemplate": "^v(?<version>.*)$"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^ansible/vars/versions\\.yml$/"],
      "matchStrings": ["node_versions:\\s*-\\s*\"(?<currentValue>.*?)\""],
      "datasourceTemplate": "node-version",
      "depNameTemplate": "node",
      "versioningTemplate": "node"
    }
  ],
  "pre-commit": {
    "enabled": true
  },
  "ansible": {
    "enabled": true,
    "managerFilePatterns": ["/(^|/)ansible/requirements\\.ya?ml$/", "/(^|/)ansible/galaxy\\.ya?ml$/"]
  }
}
